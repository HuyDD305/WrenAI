# ── OpenAI ────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...

# ── PostgreSQL (bundled example database) ─────────────────────────────────
POSTGRES_USER=wren
POSTGRES_PASSWORD=wren
POSTGRES_DB=wren

# ── Wren config ───────────────────────────────────────────────────────────
WREN_HOME=/wren-home

# ── GenBI deploy tokens (fill in when deploying apps) ─────────────────────
# VERCEL_TOKEN=
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ACCOUNT_ID=

# ── Memory backend (optional; default: lancedb) ───────────────────────────
# WREN_MEMORY_BACKEND=lancedb
# WREN_EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
